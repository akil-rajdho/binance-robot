# WhiteBit API credentials
WHITEBIT_API_KEY=your_api_key_here
WHITEBIT_API_SECRET=your_api_secret_here

# Authentication (required for production)
ADMIN_PASSWORD=change_this_to_a_strong_password
DEPLOY_TOKEN=generate_a_random_token_here

# Database (set automatically by docker-compose)
POSTGRES_DSN=postgres://bitcoin:bitcoin@postgres:5432/bitcoinrobot?sslmode=disable
REDIS_URL=redis://redis:6379
